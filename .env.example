# Copy to .env and fill in. .env is gitignored; this template is not.
#
#     cp .env.example .env
#     open -e .env          # paste your values, save, close
#
# Everything here is optional -- the app runs without any of it, on an
# in-memory store seeded from sample_reviews.json.

# Needed only by the Auditor agent (python -m vouchnet.auditor).
# Use a key scoped to this project so it can be revoked on its own:
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Needed only for real persistence. Without these, reviews live in memory for
# the life of the process. Supabase dashboard > Settings > API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated agents that seed TrustRank -- the root of trust. Anything
# reachable from this set inherits credibility, so it is a policy decision.
# Defaults to "ricardo,vouchnet-auditor".
VOUCHNET_SEEDS=
